# Copy this file to .env and fill in values before deploying.
# Replace <VM_PUBLIC_IP> with the actual public IP or domain of your VM.

# Public-facing URL of the backend API (used by the browser, not Docker networking)
NEXT_PUBLIC_API_URL=http://<VM_PUBLIC_IP>:8000

# Allowed CORS origin for the backend (must match the URL users open in their browser)
FRONTEND_ORIGIN=http://<VM_PUBLIC_IP>:3000

# Gemini API key — keep this secret, never commit it
GEMINI_API_KEY=your_gemini_api_key_here
